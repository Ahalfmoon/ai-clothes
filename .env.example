# ====================================
# Vercel Deployment Environment Variables
# ====================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in your project settings

# ====================================
# Vercel Provided (Auto-configured)
# ====================================
# These are automatically set by Vercel when you enable the services
# POSTGRES_URL=postgresql://...
# POSTGRES_PRISMA_URL=postgresql://...
# POSTGRES_HOST=...
# POSTGRES_USER=...
# POSTGRES_PASSWORD=...
# POSTGRES_DATABASE=...
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# BLOB_STORE_ID=store_...

# ====================================
# Database Configuration
# ====================================
# Local development (optional)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_outfit

# ====================================
# AI Service (Choose One)
# ====================================

# 火山引擎图片换装（推荐 - 豆包同源技术）
# 获取方式: https://console.volcengine.com/iam/keymanage
VOLCENGINE_ACCESS_KEY=your_volcengine_access_key
VOLCENGINE_SECRET_KEY=your_volcengine_secret_key

# Together AI (Recommended - $25 free credit, cheap Stable Diffusion)
# Get your key at: https://together.ai
# TOGETHER_API_KEY=your_together_api_key_here

# OR OpenAI (DALL-E + GPT)
# Get your key at: https://platform.openai.com
# OPENAI_API_KEY=your_openai_api_key_here

# OR Replicate (Multiple AI models)
# Get your key at: https://replicate.com
# REPLICATE_API_TOKEN=your_replicate_token_here

# ====================================
# Application Settings
# ====================================
NODE_ENV=production
SERVER_PORT=3000

# ====================================
# CORS Settings
# ====================================
# Comma-separated list of allowed origins
# Leave empty for wildcard (not recommended for production)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ====================================
# Optional: Custom Domain
# ====================================
# If you have a custom domain configured in Vercel
# BASE_URL=https://yourdomain.com
BASE_URL=https://your-project.vercel.app

# ====================================
# Configuration Notes
# ====================================
# 1. Vercel Postgres: 启用后自动配置环境变量
# 2. Vercel Blob: 需要手动在 Dashboard 创建 Access Token
# 3. AI Keys: 可选，Mock 版本不需要
# 4. 本地开发: 可以使用本地数据库和文件存储
