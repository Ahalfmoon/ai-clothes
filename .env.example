# ====================================
# Vercel Deployment Environment Variables
# ====================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in your project settings

# ====================================
# Vercel Provided (Auto-configured)
# ====================================
# These are automatically set by Vercel when you enable the services
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# BLOB_READ_WRITE_TOKEN=

# ====================================
# AI Service (Choose One)
# ====================================

# Together AI (Recommended - $25 free credit, cheap Stable Diffusion)
# Get your key at: https://together.ai
TOGETHER_API_KEY=your_together_api_key_here

# OR OpenAI (DALL-E + GPT)
# Get your key at: https://platform.openai.com
# OPENAI_API_KEY=your_openai_api_key_here

# OR Replicate (Multiple AI models)
# Get your key at: https://replicate.com
# REPLICATE_API_TOKEN=your_replicate_token_here

# ====================================
# Application Settings
# ====================================
NODE_ENV=production
SERVER_PORT=3000

# ====================================
# CORS Settings
# ====================================
# Comma-separated list of allowed origins
# Leave empty for wildcard (not recommended for production)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ====================================
# Optional: Custom Domain
# ====================================
# If you have a custom domain configured in Vercel
# BASE_URL=https://yourdomain.com
BASE_URL=https://your-project.vercel.app
